generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum IncidentType {
  ROBBERY
  KIDNAPPING
  FIRE
  POLICE_EXTORTION
  ROADBLOCK
  ACCIDENT
  SUSPICIOUS_ACTIVITY
}

enum SosStatus {
  active
  resolved
}

enum GuardianBadge {
  NONE
  BRONZE
  SILVER
  GOLD
}

enum SosResponderStatus {
  coming
  unable
}

model User {
  id                String           @id @default(uuid())
  name              String
  phone             String
  email             String           @unique
  photoUrl          String           @default("")
  passwordHash      String
  homeLatitude      Float?
  homeLongitude     Float?
  guardianAvailable Boolean          @default(false)
  guardianVerificationBadge GuardianBadge @default(NONE)
  guardianAssistCount Int            @default(0)
  createdAt         DateTime         @default(now())
  trustedContacts   TrustedContact[]
  incidents         Incident[]
  sosAlerts         SosAlert[]
}

model TrustedContact {
  id           String   @id @default(uuid())
  userId       String
  contactName  String
  phone        String
  relationship String
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Incident {
  id          String       @id @default(uuid())
  type        IncidentType
  description String
  reportedBy  String
  anonymous   Boolean      @default(false)
  imageUri    String?
  latitude    Float
  longitude   Float
  timestamp   DateTime     @default(now())
  verified    Boolean      @default(false)
  upvotes     Int          @default(0)
  upvotedBy   String[]     @default([])
  verificationCount Int    @default(0)
  trustScore  Int          @default(40)
  reporterCredibilityScore Int @default(50)
  verifiedBy  String[]     @default([])
  reporter    User         @relation(fields: [reportedBy], references: [id], onDelete: Cascade)

  @@index([latitude, longitude])
  @@index([timestamp])
}

model SosAlert {
  id         String    @id @default(uuid())
  userId     String
  requesterName String?
  requesterPhone String?
  latitude   Float
  longitude  Float
  timestamp  DateTime  @default(now())
  status     SosStatus @default(active)
  escalationLevel Int   @default(1)
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  responders SosResponder[]

  @@index([status, timestamp])
}

model SosResponder {
  id         String            @id @default(uuid())
  alertId    String
  userId     String
  status     SosResponderStatus
  etaMinutes Int?
  updatedAt  DateTime          @default(now())
  alert      SosAlert          @relation(fields: [alertId], references: [id], onDelete: Cascade)

  @@unique([alertId, userId])
  @@index([alertId])
}

model NotificationEvent {
  id             String   @id @default(uuid())
  category       String
  message        String
  recipientIds   String[]
  metadata       Json
  createdAt      DateTime @default(now())

  @@index([createdAt])
}
